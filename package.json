{
	"name": "obsidian-history-maps",
	"version": "1.0.0",
	"description": "Adds history map view to Obsidian Bases.",
	"main": "main.js",
	"scripts": {
		"dev": "node scripts/generate-rtl-plugin.mjs && vite build --watch --mode development",
		"build": "node scripts/generate-rtl-plugin.mjs && tsc -noEmit -skipLibCheck && vite build --mode production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"maps",
		"bases"
	],
	"author": "Obsidian",
	"authorUrl": "xjiaxiang86@gmail.com",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "24.6.1",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "8.58.0",
		"builtin-modules": "5.0.0",
		"obsidian": "latest",
		"tslib": "2.8.1",
		"typescript": "6.0.2",
		"vite": "^7.0.0"
	},
	"dependencies": {
		"@mapbox/mapbox-gl-rtl-text": "^0.3.0",
		"@tweakpane/core": "^2.0.5",
		"maplibre-gl": "5.22.0",
		"pmtiles": "^4.4.0",
		"tweakpane": "^4.0.5"
	}
}
